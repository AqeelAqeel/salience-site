# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server-side writes for /friends cockpit (Gmail tokens, thread upserts, AI state).
# Get this from: Supabase Dashboard → Project Settings → API → service_role.
# NEVER expose to the client.
NEXT_SECRET_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
NEXT_SECRET_SUPABASE_SECRET_KEY=your-supabase-secret-key-here

# Google OAuth credentials — used to refresh Gmail access tokens server-side.
# These are the SAME client_id / client_secret you configure in the Supabase
# Dashboard → Authentication → Providers → Google. Duplicate them here so
# /friends/[slug] can refresh expired tokens without re-prompting the user.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret